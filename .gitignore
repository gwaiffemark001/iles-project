# ========================================
# Django Backend (iles-backend)
# ========================================

# Python compiled files
__pycache__/
*.py[cod]
*$py.class
*.so

# Django specific
*.log
*.pot
db.sqlite3
db.sqlite3-journal
*.sqlite3
media/
staticfiles/
local_settings.py

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/

# Distribution / packaging
*.egg-info/
dist/
build/
*.egg
.eggs/

# Testing / coverage
.coverage
htmlcov/
.tox/
.nox/
.pytest_cache/
.cache/

# Environment variables (very important!)
.env
.env.local
.env.*.local


# ========================================
# React Frontend (iles-frontend)
# ========================================

# Dependencies
iles-frontend/node_modules/

# Production builds
iles-frontend/build/
iles-frontend/dist/

# Logs and debugging
iles-frontend/*.log
iles-frontend/npm-debug.log*
iles-frontend/yarn-debug.log*
iles-frontend/yarn-error.log*

